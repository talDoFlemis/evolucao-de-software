false\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tr = file\n\t\t}\n\n\t\terr := state.cat(r, bw)\n\t\tif filename != \"-\" {\n\t\t\tif closer, isCloser := r.(io.Closer); isCloser {\n\t\t\t\t_ = closer.Close()\n\t\t\t}\n\t\t}\n\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"%s: %s: %s\\n\", filepath.Base(os.Args[0]), filename, getOSErrorMessage(err))\n\t\t\tok = false\n\t\t}\n\t}\n\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n}\n\nfunc (s *catState) cat(r io.Reader, bw *bufio.Writer) error {\n\t// If no formatting options are set, use the fast path (io.Copy)\n\tif !s.number && !s.showEnds && !s.showNonprinting && !s.showTabs && !s.squeezeBlank {\n\t\t_, err := io.Copy(bw, r)\n\t\treturn err\n\t}\n\n\tbr := bufio.NewReader(r)\n\tfor {\n\t\t// 1. Process newlines\n\t\tfor {\n\t\t\tb, err := br.Peek(1)\n\t\t\tif err != nil {\n\t\t\t\tif err == io.EOF {\n\t\t\t\t\treturn nil\n\t\t\t\t}\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif b[0] != '\\n' {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\t// Consume the newline\n\t\t\t_, _ = br.ReadByte()\n\t\t\tif err := s.handleNewline(bw); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\n\t\t// Read the first non-newline character\n\t\tch, err := br.ReadByte()\n\t\tif err != nil {\n\t\t\tif err == io.EOF {\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\treturn err\n\t\t}\n\n\t\tif s.pendingCR {\n\t\t\tif err := bw.WriteByte('\\r'); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\ts.pendingCR = false\n\t\t}\n\n\t\tif s.newlines >= 0 && s.number {\n\t\t\ts.lineNumber++\n\t\t\tif err := writeLineNumber(bw, s.lineNumber); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\n\t\t// Process characters until a newline\n\t\tfor {\n\t\t\tif s.showNonprinting {\n\t\t\t\tif ch >= 32 {\n\t\t\t\t\tif ch < 127 {\n\t\t\t\t\t\tif err := bw.WriteByte(ch); err != nil {\n\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t}\n\t\t\t\t\t} else if ch == 127 {\n\t\t\t\t\t\tif _, err := bw.WriteString(\"^?\"); err != nil {\n\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t}\n\t\t\t\t\t} else {\n\t\t\t\t\t\tif _, err := bw.WriteString(\"M-\"); err != nil {\n\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t}\n\t\t\t\t\t\tif ch >= 128+32 {\n\t\t\t\t\t\t\tif ch < 128+127 {\n\t\t\t\t\t\t\t\tif err := bw.WriteByte(ch - 128); err != nil {\n\t\t\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\t\tif _, err := bw.WriteString(\"^?\"); err != nil {\n\t\t\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tif _, err := bw.WriteString(\"^\"); err != nil {\n\t\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\tif err := bw.WriteByte(ch - 128 + 64); err != nil {\n\t\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t} else if ch == '\\t' && !s.showTabs {\n\t\t\t\t\tif err := bw.WriteByte('\\t'); err != nil {\n\t\t\t\t\t\treturn err\n\t\t\t\t\t}\n\t\t\t\t} else if ch == '\\n' {\n\t\t\t\t\ts.newlines = -1\n\t\t\t\t\tif err := s.handleNewline(bw); err != nil {\n\t\t\t\t\t\treturn err\n\t\t\t\t\t}\n\t\t\t\t\tbreak\n\t\t\t\t} else {\n\t\t\t\t\tif _, err := bw.WriteString(\"^\"); err != nil {\n\t\t\t\t\t\treturn err\n\t\t\t\t\t}\n\t\t\t\t\tif err := bw.WriteByte(ch + 64); err != nil {\n\t\t\t\t\t\treturn err\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tif ch == '\\t' && s.showTabs {\n\t\t\t\t\tif _, err := bw.WriteString(\"^I\"); err != nil {\n\t\t\t\t\t\treturn err\n\t\t\t\t\t}\n\t\t\t\t} else if ch != '\\n' {\n\t\t\t\t\tif ch == '\\r' && s.showEnds {\n\t\t\t\t\t\tnextByte, peekErr := br.Peek(1)\n\t\t\t\t\t\tif peekErr == nil && nextByte[0] == '\\n' {\n\t\t\t\t\t\t\tif _, err := bw.WriteString(\"^M\"); err != nil {\n\t\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t} else if peekErr == io.EOF {\n\t\t\t\t\t\t\ts.pendingCR = true\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tif err := bw.WriteByte('\\r'); err != nil {\n\t\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t} else {\n\t\t\t\t\t\tif err := bw.WriteByte(ch); err != nil {\n\t\t\t\t\t\t\treturn err\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\ts.newlines = -1\n\t\t\t\t\tif err := s.handleNewline(bw); err != nil {\n\t\t\t\t\t\treturn err\n\t\t\t\t\t}\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\n\t\t\tvar readErr error\n\t\t\tch, readErr = br.ReadByte()\n\t\t\tif readErr != nil {\n\t\t\t\tif readErr == io.EOF {\n\t\t\t\t\treturn nil\n\t\t\t\t}\n\t\t\t\treturn readErr\n\t\t\t}\n\t\t}\n\n\t}\n}\n\nfunc (s *catState) handleNewline(bw *bufio.Writer) error {\n\ts.newlines++\n\tif s.newlines >= 2 {\n\t\ts.newlines = 2\n\t\tif s.squeezeBlank {\n\t\t\treturn nil\n\t\t}\n\t}\n\n\tif s.newlines > 0 && s.number && !s.numberNonblank {\n\t\ts.lineNumber++\n\t\tif err := writeLineNumber(bw, s.lineNumber); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\tif s.showEnds {\n\t\tif s.pendingCR {\n\t\t\tif _, err := bw.WriteString(\"^M\"); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\ts.pendingCR = false\n\t\t}\n\t\tif err := bw.WriteByte('$'); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn bw.WriteByte('\\n')\n}\n\nfunc writeLineNumber(w io.Writer, num int) error {\n\t_, err := fmt.Fprintf(w, \"%6d\\t\", num)\n\treturn err\n}\n\nfunc getOSErrorMessage(err error) string {\n\tif pe, ok := err.(*os.PathError); ok {\n\t\terr = pe.Err\n\t}\n\tmsg := err.Error()\n\tif len(msg) > 0 {\n\t\trunes := []rune(msg)\n\t\tif runes[0] >= 'a' && runes[0] <= 'z' {\n\t\t\trunes[0] = runes[0] - 'a' + 'A'\n\t\t}\n\t\tmsg = string(runes)\n\t}\n\treturn msg\n}\n\nfunc printTryHelp() {\n\tfmt.Fprintf(os.Stderr, \"Try '%s --help' for more information.\\n\", filepath.Base(os.Args[0]))\n}\n\nfunc printHelp() {\n\tfmt.Printf(\"Usage: %s [OPTION]... [FILE]...\\n\", filepath.Base(os.Args[0]))\n\tfmt.Println(\"Concatenate FILE(s) to standard output.\")\n\tfmt.Println()\n\tfmt.Println(\"With no FILE, or when FILE is -, read standard input.\")\n\tfmt.Println()\n\tfmt.Println(\"  -A, --show-all           equivalent to -vET\")\n\tfmt.Println(\"  -b, --number-nonblank    number nonempty output lines, overrides -n\")\n\tfmt.Println(\"  -e                       equivalent to -vE\")\n\tfmt.Println(\"  -E, --show-ends          display $ or ^M$ at end of each line\")\n\tfmt.Println(\"  -n, --number             number all output lines\")\n\tfmt.Println(\"  -s, --squeeze-blank      suppress repeated empty output lines\")\n\tfmt.Println(\"  -t                       equivalent to -vT\")\n\tfmt.Println(\"  -T, --show-tabs          display TAB characters as ^I\")\n\tfmt.Println(\"  -u                       (ignored)\")\n\tfmt.Println(\"  -v, --show-nonprinting   use ^ and M- notation, except for LFD and TAB\")\n\tfmt.Println(\"      --help        display this help and exit\")\n\tfmt.Println(\"      --version     output version information and exit\")\n\tfmt.Println()\n\tfmt.Println(\"Examples:\")\n\tfmt.Printf(\"  %s f - g  Output f's contents, then standard input, then g's contents.\\n\", filepath.Base(os.Args[0]))\n\tfmt.Printf(\"  %s        Copy standard input to standard output.\\n\", filepath.Base(os.Args[0]))\n}\n\nfunc printVersion() {\n\tfmt.Printf(\"%s (GNU coreutils) 9.1-spectra-go\\n\", filepath.Base(os.Args[0]))\n\tfmt.Println(\"Copyright (C) 2026 Free Software Foundation, Inc.\")\n\tfmt.Println(\"License GPLv3+: GNU GPL version 3 or later <https://gnu.org/licenses/gpl.html>.\")\n\tfmt.Println(\"This is free software: you are free to change and redistribute.  There is NO WARRANTY.\")\n\tfmt.Println(\"Written by Torbjorn Granlund and Richard M. Stallman.\")\n}\n"}]}